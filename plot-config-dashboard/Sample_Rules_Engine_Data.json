  "permissibility_matrix": {
    "residential_zone": {
      "permitted": ["single_unit", "multi_unit", "ews_lig", "affordable"],
      "conditional": ["mixed_use"],
      "prohibited": ["heavy_industrial", "hazardous"]
    },
    "commercial_zone": {
      "permitted": ["commercial", "mixed_use"],
      "conditional": ["single_unit"],
      "prohibited": ["heavy_industrial"]
    },
    "industrial_zone": {
      "permitted": ["light_industrial", "warehouse"],
      "conditional": ["commercial"],
      "prohibited": ["residential"]
    }
  },

  "calculations": {
    "FAR": {
      "formula": "totalFloorArea / netPlotArea",
      "description": "Floor Area Ratio = Total Built-up Area / Net Plot Area",
      "exclusions": ["basement_parking", "staircase_overhead", "lift_shaft", "balcony_upto_1.5m"]
    },
    "groundCoverage": {
      "formula": "(footprintArea / plotArea) * 100",
      "description": "Percentage of plot covered by building footprint at ground floor",
      "exclusions": ["ramp", "pathway", "pergola_without_roof"]
    },
    "numberOfStoreys": {
      "formula": "ceil(proposedHeight / 3.5)",
      "description": "Approximate storey count (assume 3.5m per floor)",
      "notes": "Actual storey count from architectural drawings governs."
    }
  },

  "definitions": {
    "plotArea": "Total area of the plot as per sale deed / layout plan, in sqm.",
    "plotWidth": "Dimension of plot along the road frontage, in metres.",
    "netPlotArea": "Plot area after deducting road widening surrender, in sqm.",
    "buildingHeight": "Measured from finished road level to topmost point including parapet.",
    "FAR": "Floor Area Ratio — ratio of total built-up area to net plot area.",
    "groundCoverage": "Percentage of plot area covered by ground floor footprint.",
    "frontSetback": "Minimum distance from road-facing plot boundary to building facade.",
    "sideSetback": "Minimum distance from side plot boundary to nearest wall of building.",
    "rearSetback": "Minimum distance from rear plot boundary to building.",
    "ECS": "Equivalent Car Space — standard parking unit of 2.5m × 5.0m.",
    "carpetArea": "Usable floor area within walls, excluding thickness of walls and common passages.",
    "MFAR": "Maximum FAR including density bonus, TDR, and premium FAR mechanisms."
  }
}
