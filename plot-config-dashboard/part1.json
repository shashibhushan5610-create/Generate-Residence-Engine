{
    "engine_metadata": {
        "engine_id": "antigravity-zoning-engine",
        "version": "2.0.0",
        "schema_version": "1.4",
        "product": "Antigravity Generative Floor Plan System",
        "module": "Residential Zoning Rule Engine",
        "description": "Production-grade zoning rule engine for single-family independent residential houses. Defines spatial zones, room adjacency, building code constraints, environmental logic, and Vastu soft preferences.",
        "supported_building_types": [
            "single_family_residential",
            "independent_house"
        ],
        "pipeline_stage": "zone_assignment_and_constraint_evaluation",
        "dependencies": {
            "setback_engine": {
                "required": true,
                "version_min": "1.0.0",
                "description": "Setback Engine runs BEFORE this engine. Setback values are consumed as read-only input constraints.",
                "inputs_consumed": [
                    "setbacks.front",
                    "setbacks.rear",
                    "setbacks.left",
                    "setbacks.right"
                ]
            },
            "geometry_solver": {
                "required": true,
                "version_min": "1.0.0",
                "description": "Geometry Layout Solver consumes the output of this engine."
            }
        },
        "constraint_priority_hierarchy": [
            {
                "level": 1,
                "category": "functional_constraints",
                "override_allowed": false
            },
            {
                "level": 2,
                "category": "nbc_building_code_constraints",
                "override_allowed": false
            },
            {
                "level": 3,
                "category": "geometry_constraints",
                "override_allowed": false
            },
            {
                "level": 4,
                "category": "environmental_constraints",
                "override_allowed": false
            },
            {
                "level": 5,
                "category": "vastu_preferences",
                "override_allowed": true,
                "note": "Soft constraints only. Must never override functional or code constraints."
            }
        ],
        "pipeline_order": [
            "plot_analysis",
            "room_adjacency_graph_generation",
            "zone_assignment",
            "constraint_evaluation",
            "geometry_layout_solver_input"
        ],
        "setback_policy": {
            "policy": "READ_ONLY",
            "note": "This engine does NOT calculate setbacks. Setbacks are injected as non-buildable spatial boundaries. Setback areas may contain: parking, entry_path, landscape, service_access, ventilation_openings.",
            "non_buildable": true,
            "permitted_uses_in_setback": [
                "parking",
                "entry_path",
                "landscape",
                "service_access",
                "ventilation_openings"
            ]
        },
        "created_by": "Antigravity Architecture Engine Team",
        "last_updated": "2025-01-01",
        "units": {
            "length": "meters",
            "area": "square_meters",
            "angle": "degrees"
        }
    },
    "plot_input_schema": {
        "description": "Expected input schema for plot and setback data provided by external engines.",
        "required_fields": [
            "plot_id",
            "plot_width",
            "plot_depth",
            "plot_area",
            "plot_shape",
            "plot_orientation",
            "road_facing",
            "setbacks"
        ],
        "schema": {
            "plot_id": {
                "type": "string",
                "description": "Unique identifier for the plot."
            },
            "plot_width": {
                "type": "number",
                "unit": "meters",
                "min": 5.0
            },
            "plot_depth": {
                "type": "number",
                "unit": "meters",
                "min": 8.0
            },
            "plot_area": {
                "type": "number",
                "unit": "sqm",
                "min": 40.0
            },
            "plot_shape": {
                "type": "string",
                "enum": [
                    "rectangular",
                    "square",
                    "l_shaped",
                    "irregular",
                    "corner_plot",
                    "flag_plot"
                ],
                "default": "rectangular"
            },
            "plot_orientation": {
                "type": "string",
                "enum": [
                    "north_facing",
                    "south_facing",
                    "east_facing",
                    "west_facing",
                    "north_east_facing",
                    "north_west_facing",
                    "south_east_facing",
                    "south_west_facing"
                ]
            },
            "road_facing": {
                "type": "array",
                "items": {
                    "type": "string",
                    "enum": [
                        "north",
                        "south",
                        "east",
                        "west"
                    ]
                },
                "description": "Sides of the plot that face a road or public access."
            },
            "number_of_floors": {
                "type": "integer",
                "min": 1,
                "max": 4,
                "default": 2
            },
            "floor_height": {
                "type": "number",
                "unit": "meters",
                "default": 3.0,
                "min": 2.75,
                "max": 3.6
            },
            "setbacks": {
                "type": "object",
                "description": "Read-only setback values injected from the Setback Engine.",
                "required": [
                    "front",
                    "rear",
                    "left",
                    "right"
                ],
                "properties": {
                    "front": {
                        "type": "number",
                        "unit": "meters"
                    },
                    "rear": {
                        "type": "number",
                        "unit": "meters"
                    },
                    "left": {
                        "type": "number",
                        "unit": "meters"
                    },
                    "right": {
                        "type": "number",
                        "unit": "meters"
                    }
                }
            },
            "buildable_area": {
                "type": "object",
                "description": "Computed buildable envelope after setbacks. Read-only from Setback Engine.",
                "properties": {
                    "width": {
                        "type": "number",
                        "unit": "meters"
                    },
                    "depth": {
                        "type": "number",
                        "unit": "meters"
                    },
                    "area": {
                        "type": "number",
                        "unit": "sqm"
                    }
                }
            },
            "terrain": {
                "type": "string",
                "enum": [
                    "flat",
                    "sloped",
                    "terraced"
                ],
                "default": "flat"
            },
            "climate_zone": {
                "type": "string",
                "enum": [
                    "composite",
                    "hot_dry",
                    "warm_humid",
                    "cold",
                    "temperate"
                ],
                "default": "composite"
            },
            "plot_size_category": {
                "type": "string",
                "enum": [
                    "small",
                    "medium",
                    "large",
                    "very_large"
                ],
                "description": "Derived from plot_area. Small: <100sqm, Medium: 100-200sqm, Large: 200-400sqm, Very Large: >400sqm"
            }
        },
        "size_category_thresholds": {
            "small": {
                "min_area": 0,
                "max_area": 100
            },
            "medium": {
                "min_area": 100,
                "max_area": 200
            },
            "large": {
                "min_area": 200,
                "max_area": 400
            },
            "very_large": {
                "min_area": 400,
                "max_area": null
            }
        }
    },
    "zones": {
        "entry_zone": {
            "zone_id": "entry_zone",
            "label": "Entry Zone",
            "purpose": "Controls access from the street/exterior to the interior. Acts as the first threshold and transition buffer between public exterior and private interior.",
            "typical_location": "front_of_plot",
            "priority_floor": [
                0
            ],
            "rooms": [
                "gate",
                "entry_walkway",
                "porch",
                "foyer"
            ],
            "adjacency_preferences": {
                "must_be_adjacent_to": [
                    "public_zone"
                ],
                "preferred_adjacent_to": [
                    "vehicle_zone",
                    "circulation_zone"
                ],
                "must_face": [
                    "road_side",
                    "front_setback"
                ]
            },
            "forbidden_adjacencies": [
                "private_zone",
                "kitchen_zone"
            ],
            "environmental_requirements": {
                "natural_light": "desirable",
                "ventilation": "passive_acceptable",
                "shading": "recommended_for_porch"
            },
            "notes": "Gate and entry_walkway may occupy front setback area. Foyer must be inside buildable boundary."
        },
        "public_zone": {
            "zone_id": "public_zone",
            "label": "Public Zone",
            "purpose": "Spaces used for formal social interaction and guest reception. Must be accessible from entry without crossing private or family zones.",
            "typical_location": "front_portion_of_buildable_area",
            "priority_floor": [
                0
            ],
            "rooms": [
                "drawing_room",
                "guest_toilet"
            ],
            "adjacency_preferences": {
                "must_be_adjacent_to": [
                    "entry_zone"
                ],
                "preferred_adjacent_to": [
                    "circulation_zone",
                    "family_zone"
                ],
                "must_face": [
                    "front_or_side"
                ]
            },
            "forbidden_adjacencies": [
                "private_zone",
                "kitchen_zone",
                "utility"
            ],
            "environmental_requirements": {
                "natural_light": "required",
                "ventilation": "required",
                "view": "preferred_to_front_or_garden"
            },
            "notes": "Guest toilet must not open directly into drawing room. Must access via corridor/lobby."
        },
        "family_zone": {
            "zone_id": "family_zone",
            "label": "Family Zone",
            "purpose": "Core social hub of the house for private family interaction, dining, and relaxation. Acts as the central connector in the spatial graph.",
            "typical_location": "center_of_plan",
            "priority_floor": [
                0,
                1
            ],
            "rooms": [
                "family_living",
                "dining",
                "pooja"
            ],
            "adjacency_preferences": {
                "must_be_adjacent_to": [
                    "kitchen_zone",
                    "circulation_zone"
                ],
                "preferred_adjacent_to": [
                    "entry_zone",
                    "public_zone",
                    "private_zone"
                ],
                "hub_room": "family_living",
                "must_face": [
                    "courtyard_or_garden_preferred"
                ]
            },
            "forbidden_adjacencies": [
                "vehicle_zone"
            ],
            "environmental_requirements": {
                "natural_light": "required",
                "ventilation": "required",
                "cross_ventilation": "preferred"
            },
            "notes": "Family Living is the primary spatial hub. All major circulation connections pass through or adjacent to family_living."
        },
        "private_zone": {
            "zone_id": "private_zone",
            "label": "Private Zone",
            "purpose": "Sleeping and personal retreat spaces. Must be secluded from public and semi-public zones. Accessed only via corridor or family living.",
            "typical_location": "rear_or_upper_floor",
            "priority_floor": [
                1,
                2
            ],
            "rooms": [
                "master_bedroom",
                "bedroom"
            ],
            "adjacency_preferences": {
                "must_be_adjacent_to": [
                    "circulation_zone",
                    "toilet_zone"
                ],
                "preferred_adjacent_to": [
                    "family_zone"
                ],
                "preferred_location": [
                    "rear_of_plot",
                    "upper_floors"
                ]
            },
            "forbidden_adjacencies": [
                "entry_zone",
                "public_zone",
                "vehicle_zone",
                "kitchen_zone"
            ],
            "environmental_requirements": {
                "natural_light": "required",
                "ventilation": "required",
                "cross_ventilation": "preferred",
                "noise_buffer": "required_from_road"
            },
            "notes": "Master bedroom preferred at South-West (Vastu soft rule). Bedrooms on ground floor only if plot is single storey."
        },
        "kitchen_zone": {
            "zone_id": "kitchen_zone",
            "label": "Kitchen Zone",
            "purpose": "Food preparation, storage, and utility operations. Must have direct access to dining and external ventilation or utility yard.",
            "typical_location": "rear_portion_of_plan",
            "priority_floor": [
                0
            ],
            "rooms": [
                "kitchen",
                "pantry",
                "store_room",
                "utility"
            ],
            "adjacency_preferences": {
                "must_be_adjacent_to": [
                    "family_zone"
                ],
                "dining_connection": "required",
                "preferred_adjacent_to": [
                    "outdoor_zone",
                    "toilet_zone"
                ],
                "preferred_location": [
                    "south_east_vastu_soft",
                    "rear_or_side_external_wall"
                ]
            },
            "forbidden_adjacencies": [
                "entry_zone",
                "public_zone",
                "private_zone"
            ],
            "environmental_requirements": {
                "natural_light": "required",
                "ventilation": "required",
                "exhaust": "required",
                "external_wall_or_ots": "required",
                "utility_yard_access": "preferred"
            },
            "notes": "Kitchen must connect to dining. Utility to connect to kitchen. Ventilation priority: external_wall > utility_yard > OTS."
        },
        "toilet_zone": {
            "zone_id": "toilet_zone",
            "label": "Toilet Zone",
            "purpose": "Sanitation and bathing. Bathrooms attached to bedrooms; powder rooms/guest toilets accessed via corridor. Clustered near kitchen and utility for plumbing efficiency.",
            "typical_location": "distributed_near_bedrooms_and_utility",
            "priority_floor": [
                0,
                1
            ],
            "rooms": [
                "bathroom",
                "powder_room"
            ],
            "adjacency_preferences": {
                "must_be_adjacent_to": [
                    "private_zone",
                    "circulation_zone"
                ],
                "preferred_adjacent_to": [
                    "kitchen_zone"
                ],
                "cluster_near": [
                    "kitchen",
                    "utility"
                ],
                "bedroom_toilets": "attached_to_bedroom"
            },
            "forbidden_adjacencies": [
                "drawing_room",
                "dining",
                "pooja"
            ],
            "environmental_requirements": {
                "natural_light": "preferred",
                "ventilation": "required",
                "external_wall_or_ots": "required"
            },
            "notes": "Guest toilet: accessed via corridor/lobby only. Bedroom toilets: attached directly. Cluster plumbing near kitchen/utility to reduce piping runs."
        },
        "circulation_zone": {
            "zone_id": "circulation_zone",
            "label": "Circulation Zone",
            "purpose": "Movement infrastructure connecting all zones. Enables access to private zones without crossing public zones. Houses staircase and landings.",
            "typical_location": "central_or_spine",
            "priority_floor": [
                0,
                1,
                2
            ],
            "rooms": [
                "corridor",
                "staircase",
                "landing"
            ],
            "adjacency_preferences": {
                "must_be_adjacent_to": [
                    "family_zone",
                    "private_zone",
                    "toilet_zone"
                ],
                "preferred_adjacent_to": [
                    "entry_zone",
                    "public_zone"
                ],
                "staircase_location": {
                    "small_plot": "near_entry_or_parking",
                    "large_plot": "inside_family_zone_or_corridor"
                }
            },
            "forbidden_adjacencies": [
                "vehicle_zone"
            ],
            "environmental_requirements": {
                "natural_light": "preferred",
                "ventilation": "passive_acceptable",
                "staircase_ventilation": "required"
            }
        },
        "outdoor_zone": {
            "zone_id": "outdoor_zone",
            "label": "Outdoor / Environmental Zone",
            "purpose": "Open-to-sky spaces providing light, ventilation, and amenity. Includes courtyards, balconies, OTS voids, backyard, and garden.",
            "typical_location": "distributed_per_generation_rules",
            "priority_floor": [
                0,
                1,
                2
            ],
            "rooms": [
                "courtyard",
                "balcony",
                "ots",
                "backyard",
                "garden"
            ],
            "adjacency_preferences": {
                "courtyard": {
                    "preferred_adjacent_to": [
                        "family_zone",
                        "kitchen_zone",
                        "circulation_zone"
                    ]
                },
                "balcony": {
                    "preferred_adjacent_to": [
                        "bedroom",
                        "family_living"
                    ],
                    "upper_floor_only": true
                },
                "ots": {
                    "auto_generated_when": "room_has_no_external_wall"
                },
                "backyard": {
                    "preferred_adjacent_to": [
                        "kitchen_zone",
                        "utility"
                    ]
                },
                "garden": {
                    "preferred_adjacent_to": [
                        "entry_zone",
                        "outdoor_zone"
                    ]
                }
            },
            "forbidden_adjacencies": [],
            "environmental_requirements": {
                "ots_min_size": {
                    "width": 0.9,
                    "depth": 0.9,
                    "unit": "meters"
                },
                "courtyard_min_width": {
                    "value": 2.5,
                    "unit": "meters"
                },
                "courtyard_enabled_threshold": {
                    "min_plot_area": 200,
                    "unit": "sqm"
                }
            }
        },
        "vehicle_zone": {
            "zone_id": "vehicle_zone",
            "label": "Vehicle / Parking Zone",
            "purpose": "Vehicle storage, parking, and driveway access. Typically occupies front setback area. Type depends on plot size.",
            "typical_location": "front_setback_or_side",
            "priority_floor": [
                0
            ],
            "rooms": [
                "parking",
                "driveway"
            ],
            "adjacency_preferences": {
                "must_be_adjacent_to": [
                    "entry_zone"
                ],
                "preferred_adjacent_to": [
                    "outdoor_zone"
                ],
                "must_access_from": [
                    "road_side"
                ]
            },
            "forbidden_adjacencies": [
                "private_zone",
                "family_zone",
                "kitchen_zone",
                "toilet_zone"
            ],
            "environmental_requirements": {
                "ventilation": "natural_open_or_mechanical",
                "drainage": "required"
            },
            "parking_type_by_plot_size": {
                "small": "open_parking",
                "medium": "covered_parking",
                "large": "garage_or_stilt",
                "very_large": "garage_or_stilt"
            }
        }
    },
